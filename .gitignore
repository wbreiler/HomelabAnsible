# OS / editor
.DS_Store
*.swp
*~

# Ansible fact caches and retry files
.ansible/
*.retry

# Local Ansible inventories and secrets
# Keep runnable examples and sanitized desired state tracked; ignore only the
# machine-specific files created from those examples.
/proxmox/inventory.yml
/proxmox/group_vars/proxmox_cluster.yml
/proxmox/host_vars/*.yml
/proxmox/host_vars/*/secrets.yml
/proxmox/vault.yml
/proxmox/files/gallery-dl-cookies.txt

/pbs/inventory.yml
/pbs/group_vars/pbs_servers.yml
/pbs/.vault_pass
/pbs/vault.yml

/minecraft/ansible/vault.yml
/minecraft/ansible/servers.yml
/minecraft/ansible/group_vars/all.yml

/truenas/group_vars/truenas.yml
/truenas/inventory/hosts.yml
/truenas/inventory/host_vars/*/desired_state.yml
/truenas/inventory/host_vars/*/vault.yml
/truenas/inventory/**/secrets.*
/truenas/vault-password*

/arista/inventory.yml
/arista/group_vars/arista.yml
/arista/.vault_pass

# Python
__pycache__/
*.pyc

