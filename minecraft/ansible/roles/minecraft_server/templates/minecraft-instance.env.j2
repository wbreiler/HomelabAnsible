# /etc/minecraft/{{ instance_name }}.env
# Per-instance JVM heap settings for minecraft@{{ instance_name }}.service
# Read via EnvironmentFile= in minecraft@.service
# Managed by Ansible — do not edit by hand.

XMX={{ xmx }}
XMS={{ xms }}
JVM_FLAGS={{ jvm_flags }}
# NeoForge/Forge use run.sh + user_jvm_args.txt instead of -jar server.jar
USE_RUN_SH={{ 'true' if (loader | default('')) in ['neoforge', 'forge'] else 'false' }}
